# Discord Bot Token - Get it from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Bot Prefix for prefix commands
BOT_PREFIX=!

# Database URL
# SQLite: jdbc:sqlite:botki.db
# PostgreSQL: jdbc:postgresql://localhost:5432/botki
DATABASE_URL=jdbc:sqlite:botki.db

# Bot Owner ID (your Discord user ID)
OWNER_ID=0

# Debug Mode
DEBUG_MODE=false